{
  "manifest_version": 3,
  "name": "Before You Leave",
  "version": "1.0.1",
  "description": "Never lose your Google Meet notes. Before You Leave guards the hang-up button and offers one-click AI summaries via Ask Gemini.",
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*"
      ],
      "js": [
        "template-storage.js",
        "content.js"
      ],
      "css": [
        "dialog.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "lock-icon.svg"
      ],
      "matches": [
        "https://meet.google.com/*"
      ]
    }
  ]
}
